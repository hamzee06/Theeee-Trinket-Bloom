{
  "buildCommand": "cd FrontEndd/trinketbloom && npm install && npm run build",
  "outputDirectory": "FrontEndd/trinketbloom/build",
  "installCommand": "npm install --prefix FrontEndd/trinketbloom",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
